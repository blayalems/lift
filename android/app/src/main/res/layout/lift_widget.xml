<?xml version="1.0" encoding="utf-8"?>
<!--
  Lift v1.4 — Material 3 Expressive widget layout.
  Three-row stack with a coloured leading "rail" so the widget reads as a
  product surface, not just text on a card.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <View
        android:layout_width="4dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/widget_rail" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="#C7C7C9"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_ready"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="@string/widget_detail_idle"
            android:textColor="#CDCDCD"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
